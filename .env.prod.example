# =============================================================================
# VPS/server deploy example (Traefik + TLS)
# =============================================================================

# Host directory with repos/workspaces mounted into /workspace.
# For server/VPS deploys, prefer an absolute path.
HOST_PROJECTS_DIR=/srv/openchamba/projects

# ----------------------------------------------------------------------
# OpenCode vars
# ----------------------------------------------------------------------

OPENCODE_SERVER_PORT=4096
OPENCODE_HOST=0.0.0.0
OPENCODE_DISABLE_AUTOUPDATE=true

# These are dev-only unless you explicitly publish host ports in your server setup.
OPENCODE_BIND_ADDRESS=127.0.0.1
OPENCODE_AUX_SERVER_PORT=1455

# ----------------------------------------------------------------------
# OpenChamber vars
# ----------------------------------------------------------------------

OPENCHAMBER_PORT=3000
OPENCHAMBER_HOST=0.0.0.0
OPENCHAMBER_DATA_DIR=/home/openchamber/.config/openchamber
OPENCODE_SKIP_START=true

# Required in this deploy example (application-level UI auth).
OPENCHAMBER_UI_PASSWORD=replace-with-a-long-random-password

# Keep for compatibility with local or custom setups.
OPENCHAMBER_BIND_ADDRESS=127.0.0.1

# ----------------------------------------------------------------------
# Reverse proxy / Traefik routing vars
# ----------------------------------------------------------------------

OPENCHAMBER_DOMAIN=openchamba.example.com
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt
TRAEFIK_DOCKER_NETWORK=traefik-public

NODE_ENV=production
