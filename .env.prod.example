# =============================================================================
# Production settings (Traefik + TLS)
# =============================================================================

# Host directory with repos/workspaces mounted into /workspace.
# Use an absolute path in production.
HOST_PROJECTS_DIR=/srv/openchamba/projects

# ----------------------------------------------------------------------
# OpenCode vars
# ----------------------------------------------------------------------

OPENCODE_SERVER_PORT=4096
OPENCODE_HOST=0.0.0.0
OPENCODE_DISABLE_AUTOUPDATE=true

# These are dev-only unless you explicitly publish host ports in production.
OPENCODE_BIND_ADDRESS=127.0.0.1
OPENCODE_AUX_SERVER_PORT=1455

# ----------------------------------------------------------------------
# OpenChamber vars
# ----------------------------------------------------------------------

OPENCHAMBER_PORT=3000
OPENCHAMBER_HOST=0.0.0.0
OPENCHAMBER_DATA_DIR=/home/openchamber/.config/openchamber
OPENCODE_SKIP_START=true

# Required in production (application-level UI auth).
OPENCHAMBER_UI_PASSWORD=replace-with-a-long-random-password

# Keep for compatibility with local setups.
OPENCHAMBER_BIND_ADDRESS=127.0.0.1

# ----------------------------------------------------------------------
# Traefik routing/security vars
# ----------------------------------------------------------------------

OPENCHAMBER_DOMAIN=openchamba.online
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt
TRAEFIK_DOCKER_NETWORK=traefik-public

# Required in production (edge HTTP basic auth).
# Generate hash example:
# docker run --rm httpd:2.4-alpine htpasswd -nbB admin 'change-me'
# If you paste hash directly in Compose labels you must escape $ as $$.
TRAEFIK_BASIC_AUTH_USERS=admin:$2y$05$replace-with-htpasswd-hash

NODE_ENV=production
