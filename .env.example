# =============================================================================
# Host data layout (all paths are relative to the compose project root).
# Run `./init-data-dirs.sh` before `docker compose up` to pre-create them with
# the ownership expected by the non-root containers.
#
# ./data/ssh/           - Shared SSH directory (ed25519 keypair auto-generated)
# ./data/openchamber/   - OpenChamber persistence (config, share, state, cache)
# ./data/opencode/      - OpenCode persistence (config, share, state, cache)
# ./projects/           - Workspace/repo directory accessible to both containers
# =============================================================================

# Host directory that contains the repos/workspaces OpenCode and OpenChamber can access.
# Both containers see this at /workspace.
# Example: HOST_PROJECTS_DIR=/home/alice/dev
HOST_PROJECTS_DIR=./projects

# ----------------------------------------------------------------------
# OpenCode vars
# ----------------------------------------------------------------------

# Host address used to publish the OpenCode API port.
# Keep 127.0.0.1 unless you intentionally need direct access from outside the host.
OPENCODE_BIND_ADDRESS=127.0.0.1

# Port exposed by the OpenCode service on both the container and the host.
OPENCODE_SERVER_PORT=4096

# Host port published for auxiliary OpenCode services (e.g. OAuth/auth flows).
# The container-side auxiliary service keeps listening on 1455.
OPENCODE_AUX_SERVER_PORT=1455

# Address OpenCode listens on inside the container.
# Use 0.0.0.0 so OpenChamber can reach it over the Compose network.
OPENCODE_HOST=0.0.0.0

# Disable self-updates inside the container for reproducible builds.
OPENCODE_DISABLE_AUTOUPDATE=true

# ----------------------------------------------------------------------
# OpenChamber vars
# ----------------------------------------------------------------------

# Host address used to publish the OpenChamber UI.
# Keep 127.0.0.1 unless you are exposing it through a proxy, tunnel, or another access layer.
OPENCHAMBER_BIND_ADDRESS=127.0.0.1

# Port exposed by the OpenChamber UI.
OPENCHAMBER_PORT=3000

# Address OpenChamber listens on inside the container.
OPENCHAMBER_HOST=0.0.0.0

# Data directory OpenChamber uses inside the container for settings, logs and runtime files.
# In this stack, ./data/openchamber/config is mounted here.
OPENCHAMBER_DATA_DIR=/home/openchamber/.config/openchamber

# Keep true when OpenChamber should connect to the Compose-managed OpenCode service
# instead of trying to start its own embedded OpenCode instance.
OPENCODE_SKIP_START=true

# Password that protects the OpenChamber browser UI.
# Leave it empty to disable browser auth.
# Example: OPENCHAMBER_UI_PASSWORD=change-me-before-sharing
OPENCHAMBER_UI_PASSWORD=change-me-before-sharing
