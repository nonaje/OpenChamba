# Host workspace mounted as /workspace in both containers.
HOST_PROJECTS_DIR=./projects

# Compose project name. Use a unique value per stack if you run multiple instances.
COMPOSE_PROJECT_NAME=open-chamba

# Optional override for the restart-bridge target project.
# Usually leave empty so the bridge autodetects its own Compose project.
TARGET_COMPOSE_PROJECT=

# OpenCode

# Host bind address for the OpenCode API.
OPENCODE_BIND_ADDRESS=127.0.0.1

# OpenCode API port.
OPENCODE_SERVER_PORT=4096

# Optional password for OpenCode HTTP auth.
# Leave empty unless you explicitly protect the OpenCode server.
OPENCODE_SERVER_PASSWORD=

# Host port for OpenCode auxiliary flows.
OPENCODE_AUX_SERVER_PORT=1455

# Internal listen address for the opencode container.
# This is a bind host (not a URL).
OPENCODE_HOST=0.0.0.0

# Keep disabled for reproducible containers.
OPENCODE_DISABLE_AUTOUPDATE=true

# OpenChamber

# Host bind address for the OpenChamber UI.
OPENCHAMBER_BIND_ADDRESS=127.0.0.1

# OpenChamber UI port.
OPENCHAMBER_PORT=3000

# Internal listen address inside the container.
OPENCHAMBER_HOST=0.0.0.0

# Internal config directory used by OpenChamber.
OPENCHAMBER_DATA_DIR=/home/openchamber/.config/openchamber

# Keep true so OpenChamber uses the Compose-managed OpenCode service.
OPENCODE_SKIP_START=true

# Shared token used by OpenChamber and both bridges.
# Must be long, random, and unique per stack.
OPENCODE_CONTROL_TOKEN=replace-with-a-long-random-secret

# Optional explicit token for exec-bridge.
# If empty, docker-compose uses OPENCODE_CONTROL_TOKEN as fallback.
EXEC_BRIDGE_TOKEN=

# Optional explicit token consumed by OpenChamber when calling the restart-bridge.
# If empty, reuse OPENCODE_CONTROL_TOKEN.
OPENCHAMBER_EXTERNAL_RESTART_TOKEN=

# Timeout for Docker API calls made by the restart-bridge.
DOCKER_REQUEST_TIMEOUT_MS=5000

# Internal port used by the restart-bridge service.
RESTART_BRIDGE_PORT=8080

# Path probed by restart-bridge when no Docker healthcheck exists.
OPENCODE_HEALTH_PATH=/global/health

# Shared timeout for OpenChamber and restart-bridge.
OPENCODE_RESTART_TIMEOUT_MS=90000

# Optional override for OpenChamber's restart request timeout.
OPENCHAMBER_EXTERNAL_RESTART_TIMEOUT_MS=

# Advanced exec-bridge tuning.
EXEC_BRIDGE_DEFAULT_TIMEOUT_MS=30000
EXEC_BRIDGE_MAX_TIMEOUT_MS=300000
EXEC_BRIDGE_MAX_BODY_BYTES=65536
EXEC_BRIDGE_MAX_OUTPUT_BYTES=1048576

# Browser password for OpenChamber. Empty disables UI auth.
OPENCHAMBER_UI_PASSWORD=change-me-before-sharing

# Reverse proxy / Traefik (optional)

# External domain used by `docker-compose.override.yml`.
OPENCHAMBER_DOMAIN=tenant-app.example.com

# Traefik Docker network name.
TRAEFIK_NETWORK=openchamba-traefik

# Traefik router/service name prefix.
TRAEFIK_INSTANCE_NAME=tenant-app
